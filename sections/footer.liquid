{{ 'custom.css' | asset_url | stylesheet_tag }}

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">
      {% comment %}Column 1 — Brand{% endcomment %}
      <div>
        <a href="/" class="site-footer__logo">{{ section.settings.logo_text | default: 'TRDEFI' }}<span class="dot">.</span></a>
        <p class="site-footer__tagline">{{ section.settings.tagline | default: 'Igniting imagination and joy through carefully curated toys and games for children worldwide.' }}</p>
        <div class="site-footer__social">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'social' %}
                <a href="{{ block.settings.url }}" class="site-footer__social-link" target="_blank" rel="noopener" aria-label="{{ block.settings.platform }}">
                  {{ block.settings.icon }}
                </a>
            {% endcase %}
          {% endfor %}
        </div>
      </div>

      {% comment %}Column 2 — Shop{% endcomment %}
      <div>
        <h3 class="site-footer__heading">Shop</h3>
        <ul class="site-footer__links">
          <li><a href="/collections/all">All Products</a></li>
          <li><a href="/collections/all?sort_by=created-descending">New Arrivals</a></li>
          <li><a href="/collections/all?sort_by=price-ascending">Best Sellers</a></li>
          <li><a href="/collections/sale">Sale</a></li>
        </ul>
      </div>

      {% comment %}Column 3 — Support{% endcomment %}
      <div>
        <h3 class="site-footer__heading">Support</h3>
        <ul class="site-footer__links">
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="/pages/faq">FAQs</a></li>
          <li><a href="/pages/shipping">Shipping Info</a></li>
          <li><a href="/pages/returns">Returns</a></li>
        </ul>
      </div>

      {% comment %}Column 4 — Contact{% endcomment %}
      <div>
        <h3 class="site-footer__heading">Contact</h3>
        <div class="site-footer__contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{{ section.settings.address | default: '123 Toy Street, Play City, PC 12345' }}</span>
        </div>
        <div class="site-footer__contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.35 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.59a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
          <span>{{ section.settings.phone | default: '+44 123 456 7890' }}</span>
        </div>
        <div class="site-footer__contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>{{ section.settings.email | default: 'hello@trdefi.com' }}</span>
        </div>
      </div>
    </div>

    {% comment %}Bottom bar{% endcomment %}
    <div class="site-footer__bottom">
      <p class="site-footer__copyright">&copy; {{ 'now' | date: '%Y' }} TRDEFI LTD. All rights reserved.</p>
      <div class="site-footer__policies">
        <a href="/pages/privacy">Privacy Policy</a>
        <a href="/pages/terms">Terms of Service</a>
        <a href="/pages/cookies">Cookie Policy</a>
      </div>
    </div>
  </div>

  {% comment %}Giant watermark removed{% endcomment %}
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "site-footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "TRDEFI"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Igniting imagination and joy through carefully curated toys and games for children worldwide."
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "123 Toy Street, Play City, PC 12345"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+44 123 456 7890"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "hello@trdefi.com"
    }
  ],
  "blocks": [
    {
      "type": "social",
      "name": "Social Link",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "📷"
        },
        {
          "type": "text",
          "id": "platform",
          "label": "Platform Name",
          "default": "Instagram"
        },
        {
          "type": "text",
          "id": "url",
          "label": "URL",
          "default": "https://instagram.com"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
