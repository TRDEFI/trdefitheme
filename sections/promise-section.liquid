{% comment %}
  Promise Section — TRDEFI
  Reference: 3 pink boxes with icons (van, lock, return)
{% endcomment %}

<section id="promise" class="promise-section">
  <div class="promise-section__header">
    <div class="promise-section__eyebrow">SHOP WITH CONFIDENCE</div>
    <h2 class="promise-section__title">Our Promise to You</h2>
  </div>

  <div class="promise-section__grid">
    <div class="promise-section__box" style="background-color: #ff69b4;">
      <div class="promise-section__box-icon">🚚</div>
      <div class="promise-section__box-title">Fast Delivery</div>
      <div class="promise-section__box-desc">Same day dispatch on orders before 4pm</div>
    </div>

    <div class="promise-section__box" style="background-color: #ff69b4;">
      <div class="promise-section__box-icon">🔒</div>
      <div class="promise-section__box-title">Secure Checkout</div>
      <div class="promise-section__box-desc">256-bit SSL encryption</div>
    </div>

    <div class="promise-section__box" style="background-color: #ff69b4;">
      <div class="promise-section__box-icon">↩️</div>
      <div class="promise-section__box-title">Easy Returns</div>
      <div class="promise-section__box-desc">30-day no-hassle returns</div>
    </div>
  </div>
</section>

